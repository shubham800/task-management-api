    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status is 201\", () => {\r",
                  "  pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Success is true\", () => {\r",
                  "  pm.expect(res.success).to.be.true;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User id exists\", () => {\r",
                  "  pm.expect(res.data?.user?._id).to.exist;\r",
                  "});\r",
                  "\r",
                  "if (res.data?.user?._id) {\r",
                  "  pm.environment.set(\"userId\", res.data.user._id);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"User 2\",\r\n    \"email\": \"user2@gmail.com\",\r\n    \"password\": \"password123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
